{
  "name": "deserialize-evm-agg",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^24.0.12"
  },
  "private": "true",
  "workspaces": [
    "packages/*",
    "providers/*",
    "apps/*"
  ],
  "dependencies": {
    "bn.js": "^5.2.2",
    "decimal.js": "^10.6.0",
    "deserialize-evm-server-sdk": "^4.0.0",
    "dotenv": "^17.2.1",
    "ethers": "^6.15.0",
    "redis": "^5.6.1",
    "viem": "^2.38.5",
    "web3": "^4.16.0"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:start:server": "npx ts-node apps/server/src/server.ts",
    "dev:start:index-pool": "npx ts-node apps/server/src/indexPool/index.ts",
    "dev:test:server": "npx ts-node apps/server/test.ts",
    "dev:sample": "npx ts-node sample.ts",
    "dev:quote": "npx ts-node quote.ts",
    "dev:index-pool": "npx ts-node indexPool.ts",
    "prebuild": "yarn install",
    "build:cache": "yarn workspace @deserialize-evm-agg/cache build",
    "build:graph": "yarn workspace @deserialize-evm-agg/graph build",
    "build:swap-sdk": "yarn workspace @deserialize-evm-agg/swap-contract-sdk build",
    "build:route-providers": "yarn workspace @deserialize-evm-agg/routes-providers build",
    "build:server": "yarn workspace @deserialize-evm-agg/server build",
    "build": "yarn run prebuild && yarn run build:cache && yarn run build:graph && yarn run build:swap-sdk && yarn run build:route-providers && yarn run build:server",
    "start:server": "npx pm2 start apps/server/dist/src/server.js --name evm-server",
    "start:0g-index": "npx pm2 start apps/server/dist/src/indexPool/0g.js --name 0g-pool-indexer",
    "start:base-index": "npx pm2 start apps/server/dist/src/indexPool/base.js --name base-pool-indexer",
    "start:all": "yarn run start:server && yarn run start:0g-index && yarn run start:base-index",
    "del:server": "npx pm2 del evm-server",
    "del:0g-index": " npx pm2 del 0g-pool-indexer ",
    "del:base-index": " npx pm2 del base-pool-indexer ",
    "del:all": "npx pm2 del evm-server && npx pm2 del 0g-pool-indexer && npx pm2 del base-pool-indexer ",
    "restart:server": "npx pm2 restart evm-server --update-env",
    "restart:0g-index": "npx pm2 restart 0g-pool-indexer --update-env",
    "restart:base-index": "npx pm2 restart base-pool-indexer --update-env",
    "restart:all": "npx pm2 restart evm-server --update-env && npx pm2 restart 0g-pool-indexer --update-env && npx pm2 restart base-pool-indexer --update-env",
    "log:server": "npx pm2 logs evm-server",
    "log:0g-index": "npx pm2 logs 0g-pool-indexer",
    "log:base-index": "npx pm2 logs base-pool-indexer",
    "log:all": "npx pm2 logs evm-server && npx pm2 logs 0g-pool-indexer && npx pm2 logs base-pool-indexer",
    "log:all:tail": "npx pm2 logs evm-server --raw",
    "clean": "rm -rf packages/*/dist apps/*/dist",
    "clean:build": "yarn run clean && yarn run build",
    "ch": "git pull && yarn run build && yarn run restart:all",
    "chl": "yarn run ch && yarn run log:all",
    "dev:all": "concurrently \"yarn run dev:start:server\""
  },
  "packageManager": "yarn@4.0.2+sha512.4e502bea682e7d8004561f916f1da2dfbe6f718024f6aa50bf8cd86f38ea3a94a7f1bf854a9ca666dd8eafcfb8d44baaa91bf5c7876e79a7aeac952c332f0e88"
}
